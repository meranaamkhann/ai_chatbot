# Copy this file to .env and fill in your own values. Never commit the real .env file.

# Required: get one at https://aistudio.google.com/app/apikey — no credit
# card required for the free tier.
GEMINI_API_KEY=your_gemini_api_key_here

# Required: a long random string used to sign session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=replace_with_a_long_random_string

# Optional: which Gemini model to use. gemini-flash-lite-latest has the
# most generous free-tier request quota (RPM/RPD) and is what this app
# defaults to. If you want stronger answers and can live with a lower
# daily cap, gemini-flash-latest or gemini-3.5-flash are also free-tier
# eligible — check current limits at https://ai.google.dev/gemini-api/docs/rate-limits
GEMINI_MODEL=gemini-flash-lite-latest

# Optional: comma-separated list of origins allowed to call this API
# cross-origin (e.g. https://your-frontend.com). Leave unset if the frontend
# is served by this same Flask app (the default, and the simplest free setup).
ALLOWED_ORIGINS=

# Optional: server settings
HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=false

# Optional: set to true only when served over HTTPS in production
SESSION_COOKIE_SECURE=false

# ---------------------------------------------------------------------------
# Branding (white-label) — override any of these to rebrand Sibbu for a
# specific clinic, hospital, or platform without touching application code.
# ---------------------------------------------------------------------------

# BRAND_NAME=Sibbu
# BRAND_TAGLINE=Your AI healthcare assistant
# BRAND_GREETING=Hi, I'm {brand_name}. I can help with general health questions...
# BRAND_DISCLAIMER=Sibbu provides general health information only...
# BRAND_ACCENT_COLOR=#0d9488
# BRAND_OFF_TOPIC_MESSAGE=Sorry, I can only answer health and medical related questions...
# BRAND_EMERGENCY_MESSAGE=This sounds like it could be a medical emergency...
# REPO_URL=https://github.com/meranaamkhann/ai_chatbot
